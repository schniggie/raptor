{
  "_doc": "Curated map from pre-commit ``repo:`` URLs (canonicalised — strip protocol + .git suffix, lowercase) to the underlying registry package they wrap. Lets the precommit parser emit Dependency rows with the right ecosystem so OSV CVE matching fires against the actual tool, not against a GitHub-only purl. Update by appending; never remove (older configs still benefit).",
  "_schema": {
    "<canonical_repo>": {
      "ecosystem": "PyPI | npm | RubyGems | etc.",
      "name": "<registry package name>"
    }
  },

