#!/usr/bin/env python3
"""SCA compromise-detection harness.

Walks a corpus of supply-chain compromise fixtures, runs
``raptor-sca`` on each, and asserts the expected detection
signal(s) fired. Outputs a per-fixture PASS / FAIL plus an
aggregate catch rate.

Each fixture directory under the corpus has:
  - ``fixture/`` — minimal project (manifest + lockfile only;
    no malicious payload)
  - ``expected.yaml`` — required signal(s) — kind + severity floor
  - ``metadata.yaml`` — incident name, dates, references

Usage:
  raptor-sca-compromise-check <corpus-dir> [--offline]

Exit codes:
  0  every fixture's expected signal(s) fired
  1  at least one fixture missed an expected signal
  2  argparse / corpus-walk / harness internal error

This is an operator-runnable evaluation tool, not a unit test —
the fixtures depend on the OSV / KEV / supply-chain heuristic
state of the SCA pipeline, which varies over time as advisories
land. A FAIL doesn't necessarily indicate a code regression;
read the miss list and update the fixture (or the production
detector) accordingly.
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import re
import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, Dict, List, Optional, Sequence, Tuple

# parents[1] climbs:
#   [0] libexec/  (this script's directory)
#   [1] <repo root>
_REPO_ROOT = Path(__file__).resolve().parents[1]
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

logger = logging.getLogger("raptor-sca-compromise-check")

# Safety: fixtures must contain ONLY manifest / lockfile bytes. The
# harness refuses to run any fixture containing files outside this
# allowlist — the point of the corpus is to prove we can detect
# compromises *without* unpacking malicious payloads, so a fixture
# with an installed ``node_modules/`` or a ``.tar.gz`` snuck in
# would defeat the threat model and is therefore a refusal-to-load
# condition. Curators who genuinely need to ship malicious bytes
# for a content-aware detector pull them from the Datadog encrypted
# samples archive at runtime; never check them into the corpus.
_FIXTURE_ALLOWED_FILENAMES: Tuple[str, ...] = (
    # npm / yarn / pnpm
    "package.json", "package-lock.json", "yarn.lock", "pnpm-lock.yaml",
    # Python
    "requirements.txt", "requirements-dev.txt", "pyproject.toml",
    "Pipfile", "Pipfile.lock", "poetry.lock", "setup.py", "setup.cfg",
    # Maven / Gradle
    "pom.xml", "build.gradle", "build.gradle.kts", "gradle.lockfile",
    "settings.gradle", "settings.gradle.kts",
    # Go / Rust / Ruby / .NET / PHP
    "go.mod", "go.sum", "Cargo.toml", "Cargo.lock",
    "Gemfile", "Gemfile.lock", "composer.json", "composer.lock",
    # .NET
    "packages.config",
    # Container / orchestration
    "Dockerfile", "Containerfile", "docker-compose.yml",
    "docker-compose.yaml", "Chart.yaml", "Chart.lock",
    ".gitmodules",
    # GHA
    "action.yml", "action.yaml",
)
_FIXTURE_ALLOWED_SUFFIXES: Tuple[str, ...] = (
    ".csproj", ".vbproj", ".fsproj",  # .NET project files
)

# vuln_type prefix mapping — the corpus uses short kind names; the
# harness maps each to the prefix(es) the production pipeline emits.
# Some signals have both ``sca:supply_chain:`` and ``sca:supplychain:``
# prefixes in the wild (legacy + current) so we match either.
_KIND_TO_PREFIXES: Dict[str, Tuple[str, ...]] = {
    "vuln_dep": ("sca:vulnerable_dependency",),
    "install_hook_suspicious": (
        "sca:supply_chain:install_hook_suspicious",
        "sca:supplychain:install_hook_suspicious",
    ),
    "typosquat_candidate": (
        "sca:supply_chain:typosquat_candidate",
        "sca:supplychain:typosquat_candidate",
    ),
    "recent_publish": (
        "sca:supply_chain:recent_publish",
        "sca:supplychain:recent_publish",
    ),
    "maintainer_change": (
        "sca:supply_chain:maintainer_change",
        "sca:supplychain:maintainer_change",
        "sca:supply_chain:maintainer_account_change",
        "sca:supplychain:maintainer_account_change",
    ),
    "image_capability_drift": (
        "sca:supply_chain:image_capability_drift",
    ),
    "binary_capability_delta": (
        "sca:supply_chain:binary_capability_delta",
    ),
    "sentinel_match": (
        "sca:supply_chain:sentinel_match",
        "sca:supplychain:sentinel_match",
    ),
    "yanked_version": (
        "sca:hygiene:yanked_version",
    ),
    "low_bus_factor": (
        "sca:supply_chain:low_bus_factor",
        "sca:supplychain:low_bus_factor",
    ),
}

_SEVERITY_RANK = {
    "info": 0, "low": 1, "medium": 2, "high": 3, "critical": 4,
}


@dataclass
class ExpectedSignal:
    """One required detection from ``expected.yaml``."""
    kind: str
    severity_floor: str = "info"
    require_kev: bool = False
    cve_id: Optional[str] = None

    @classmethod
    def from_dict(cls, d: Dict[str, Any]) -> "ExpectedSignal":
        return cls(
            kind=str(d.get("kind", "")),
            severity_floor=str(d.get("severity_floor", "info")),
            require_kev=bool(d.get("require_kev", False)),
            cve_id=d.get("cve_id"),
        )


@dataclass
class FixtureResult:
    name: str
    fixture_path: Path
    passed: bool
    expected: List[ExpectedSignal] = field(default_factory=list)
    matched: List[ExpectedSignal] = field(default_factory=list)
    missed: List[ExpectedSignal] = field(default_factory=list)
    note: str = ""


def _load_yaml(path: Path) -> Dict[str, Any]:
    """Minimal YAML loader — we only need top-level keys and lists
    of dicts with scalar values. Uses PyYAML if available, falls
    back to a tiny parser for the trivial subset we emit."""
    text = path.read_text(encoding="utf-8")
    try:
        import yaml
        loaded = yaml.safe_load(text)
        return loaded if isinstance(loaded, dict) else {}
    except ImportError:
        pass
    return _trivial_yaml_parse(text)


def _trivial_yaml_parse(text: str) -> Dict[str, Any]:
    """Tiny YAML parser for the corpus's expected.yaml shape only:
    top-level scalars + a ``must_detect:`` list of dicts. Hand-rolled
    so the harness has no third-party-lib dependency."""
    result: Dict[str, Any] = {}
    current_list_key: Optional[str] = None
    current_item: Optional[Dict[str, Any]] = None
    for raw in text.splitlines():
        line = raw.rstrip()
        # Strip comments
        if "#" in line and not line.startswith(" "):
            line = line.split("#", 1)[0].rstrip()
        if not line or line.lstrip().startswith("#"):
            continue
        if not line.startswith(" "):
            # top-level key
            if line.endswith(":"):
                key = line[:-1].strip()
                result[key] = []
                current_list_key = key
                current_item = None
            elif ":" in line:
                key, val = line.split(":", 1)
                result[key.strip()] = _coerce(val.strip())
                current_list_key = None
        else:
            stripped = line.strip()
            if stripped.startswith("- "):
                if current_list_key is None:
                    continue
                current_item = {}
                result[current_list_key].append(current_item)
                rest = stripped[2:].strip()
                if ":" in rest:
                    k, v = rest.split(":", 1)
                    current_item[k.strip()] = _coerce(v.strip())
            elif ":" in stripped and current_item is not None:
                k, v = stripped.split(":", 1)
                current_item[k.strip()] = _coerce(v.strip())
    return result


def _coerce(v: str) -> Any:
    if v.lower() in ("true", "yes"):
        return True
    if v.lower() in ("false", "no"):
        return False
    if v == "":
        return ""
    return v.strip('"').strip("'")


def _discover_fixtures(corpus_dir: Path) -> List[Path]:
    """Every immediate subdir of ``corpus_dir`` that contains both
    a ``fixture/`` subdir and an ``expected.yaml``."""
    if not corpus_dir.is_dir():
        return []
    out: List[Path] = []
    for entry in sorted(corpus_dir.iterdir()):
        if not entry.is_dir():
            continue
        if (entry / "fixture").is_dir() and (entry / "expected.yaml").is_file():
            out.append(entry)
    return out


def _fixture_safety_check(fixture_root: Path) -> Optional[str]:
    """Refuse to run a fixture that contains files outside the
    manifest / lockfile allowlist. The threat model is: a fixture
    is metadata-only, so the harness exercises detectors against
    pinned references without ever touching the malicious payload.
    Returns None when safe, an error string otherwise."""
    for path in fixture_root.rglob("*"):
        if path.is_dir():
            # Forbid known-installed-deps directories — these are
            # the most likely vector for malicious bytes sneaking
            # into the corpus via a careless commit.
            if path.name in {
                "node_modules", "venv", ".venv", "vendor",
                "site-packages", ".cache", "target", "build",
                "dist", "__pycache__",
            }:
                return (
                    f"fixture contains installed-deps dir {path.relative_to(fixture_root)!s}; "
                    f"manifest-only fixtures forbid this"
                )
            continue
        if not path.is_file():
            # Symlinks / sockets / devices — refuse unconditionally
            return f"fixture contains non-regular file {path.relative_to(fixture_root)!s}"
        name = path.name
        if name in _FIXTURE_ALLOWED_FILENAMES:
            continue
        if any(name.endswith(suffix) for suffix in _FIXTURE_ALLOWED_SUFFIXES):
            continue
        return (
            f"fixture contains unexpected file {path.relative_to(fixture_root)!s}; "
            f"corpus is manifest-only by policy (allowed: "
            f"{', '.join(_FIXTURE_ALLOWED_FILENAMES[:5])} ...)"
        )
    return None


def _run_sca(
    fixture_path: Path, *, offline: bool,
) -> Tuple[Optional[List[Dict[str, Any]]], str]:
    """Subprocess-invoke ``raptor-sca`` on a COPY of the fixture;
    return the parsed findings.json plus stderr-on-failure.

    Copying matters: ``raptor-sca``'s sandboxed transitive resolver
    creates a ``.home/`` directory inside the target tree (the
    sandbox's fake HOME for pip-compile / npm resolve). Scanning the
    source fixture in-place would contaminate the corpus and fail
    the next run's safety check. The copy keeps source pristine and
    the contamination dies with the tempdir.

    Uses ``--offline`` by default for hermeticity; pass
    ``offline=False`` to allow live OSV / KEV queries (slower,
    network-dependent, but safe — JSON-API queries, no code
    execution)."""
    with tempfile.TemporaryDirectory(prefix="sca-compromise-") as work_dir:
        scan_target = Path(work_dir) / "fixture"
        out_dir = Path(work_dir) / "out"
        shutil.copytree(fixture_path, scan_target)
        cmd: List[str] = [
            sys.executable, "-m", "packages.sca.cli",
            str(scan_target),
            "--out", str(out_dir),
            "--no-progress", "--no-llm",
        ]
        if offline:
            cmd.append("--offline")
        env = os.environ.copy()
        env["RAPTOR_DIR"] = str(_REPO_ROOT)
        env["_RAPTOR_TRUSTED"] = "1"
        try:
            proc = subprocess.run(
                cmd, capture_output=True, text=True, timeout=300, env=env,
            )
        except subprocess.TimeoutExpired:
            return None, "raptor-sca scan timed out after 300s"
        findings_path = out_dir / "findings.json"
        if not findings_path.is_file():
            return None, (
                f"raptor-sca did not emit findings.json (rc={proc.returncode}):"
                f" stderr={proc.stderr[:1000]}"
            )
        try:
            data = json.loads(findings_path.read_text())
        except json.JSONDecodeError as e:
            return None, f"findings.json was not valid JSON: {e}"
        if not isinstance(data, list):
            return None, f"findings.json was {type(data).__name__}, not list"
        return data, ""


def _row_matches_expected(
    row: Dict[str, Any], expected: ExpectedSignal,
) -> bool:
    """Predicate: does this finding satisfy one expected signal?"""
    vt = row.get("vuln_type", "")
    prefixes = _KIND_TO_PREFIXES.get(expected.kind)
    if not prefixes:
        return False
    if not any(vt == p or vt.startswith(p + ":") for p in prefixes):
        return False
    sev = row.get("severity", "info")
    if _SEVERITY_RANK.get(sev, 0) < _SEVERITY_RANK.get(
        expected.severity_floor, 0,
    ):
        return False
    if expected.require_kev:
        if not row.get("sca", {}).get("in_kev"):
            return False
    if expected.cve_id:
        aliases = (
            row.get("sca", {}).get("advisory", {}).get("aliases") or []
        )
        adv_id = (
            row.get("sca", {}).get("advisory", {}).get("id") or ""
        )
        if expected.cve_id not in aliases and expected.cve_id != adv_id:
            return False
    return True


def _evaluate_fixture(
    fixture_dir: Path, *, offline: bool,
) -> FixtureResult:
    """Run SCA on one fixture, score it against expected.yaml."""
    name = fixture_dir.name
    expected_path = fixture_dir / "expected.yaml"
    expected_raw = _load_yaml(expected_path).get("must_detect", []) or []
    expected: List[ExpectedSignal] = [
        ExpectedSignal.from_dict(d) for d in expected_raw if isinstance(d, dict)
    ]

    safety_err = _fixture_safety_check(fixture_dir / "fixture")
    if safety_err is not None:
        return FixtureResult(
            name=name, fixture_path=fixture_dir,
            passed=False, expected=expected, missed=expected,
            note=f"SAFETY REFUSAL: {safety_err}",
        )

    rows, err = _run_sca(fixture_dir / "fixture", offline=offline)
    if rows is None:
        return FixtureResult(
            name=name, fixture_path=fixture_dir,
            passed=False, expected=expected, missed=expected,
            note=err,
        )

    matched: List[ExpectedSignal] = []
    missed: List[ExpectedSignal] = []
    for exp in expected:
        if any(_row_matches_expected(r, exp) for r in rows):
            matched.append(exp)
        else:
            missed.append(exp)
    return FixtureResult(
        name=name, fixture_path=fixture_dir,
        passed=len(missed) == 0,
        expected=expected, matched=matched, missed=missed,
    )


def _format_report(
    results: Sequence[FixtureResult], *, json_out: bool,
) -> str:
    if json_out:
        return json.dumps(
            [
                {
                    "name": r.name,
                    "passed": r.passed,
                    "missed": [
                        {"kind": m.kind, "severity_floor": m.severity_floor}
                        for m in r.missed
                    ],
                    "note": r.note,
                }
                for r in results
            ],
            indent=2,
        )
    width = max((len(r.name) for r in results), default=20)
    lines: List[str] = []
    lines.append("")
    lines.append("=== compromise-detection report ===")
    for r in results:
        status = "PASS" if r.passed else "FAIL"
        suffix = ""
        if r.passed and r.matched:
            suffix = f" ({len(r.matched)}/{len(r.expected)} signals matched)"
        elif not r.passed:
            misses = ", ".join(m.kind for m in r.missed)
            suffix = f" — missed: {misses}"
            if r.note:
                suffix += f" [{r.note[:120]}]"
        lines.append(f"  {r.name:<{width}}  {status}{suffix}")
    passed = sum(1 for r in results if r.passed)
    total = len(results)
    rate = (passed / total * 100) if total else 0
    lines.append("")
    lines.append(f"Catch rate: {passed}/{total} ({rate:.0f}%)")
    return "\n".join(lines)


def _parse_args(argv: Sequence[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        prog="raptor-sca-compromise-check",
        description=(
            "Evaluate raptor-sca's detection of known supply-chain "
            "compromises against a corpus of fixtures."
        ),
    )
    p.add_argument(
        "corpus", type=Path,
        help="Path to the corpus directory (typically "
             "tests/sca-e2e/compromise-corpus).",
    )
    p.add_argument(
        "--offline", action="store_true", default=True,
        help="Run with ``--offline`` (hermetic, uses cached OSV / KEV "
             "data). Default. Use ``--no-offline`` for live network.",
    )
    p.add_argument(
        "--no-offline", dest="offline", action="store_false",
        help="Allow live OSV / KEV queries instead of relying on "
             "cached data.",
    )
    p.add_argument(
        "--json", action="store_true",
        help="Emit machine-readable JSON instead of the human report.",
    )
    p.add_argument(
        "--only", action="append", default=[],
        help="Restrict to fixtures whose directory name matches this "
             "substring. Repeatable.",
    )
    return p.parse_args(argv)


def main(argv: Optional[Sequence[str]] = None) -> int:
    args = _parse_args(list(argv) if argv is not None else sys.argv[1:])
    logging.basicConfig(level=logging.INFO, format="%(message)s")
    fixtures = _discover_fixtures(args.corpus)
    if args.only:
        fixtures = [
            f for f in fixtures
            if any(needle in f.name for needle in args.only)
        ]
    if not fixtures:
        print(
            f"raptor-sca-compromise-check: no fixtures found under "
            f"{args.corpus}",
            file=sys.stderr,
        )
        return 2

    results: List[FixtureResult] = []
    for fixture_dir in fixtures:
        logger.info("running %s", fixture_dir.name)
        results.append(_evaluate_fixture(fixture_dir, offline=args.offline))

    print(_format_report(results, json_out=args.json))
    return 0 if all(r.passed for r in results) else 1


if __name__ == "__main__":
    sys.exit(main())
