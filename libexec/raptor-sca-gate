#!/usr/bin/env python3
"""Fast SCA gate for pre-commit / CI hooks.

Two modes:

  raptor-sca-gate <target> [--severity high] [--fail-on-kev]
                  [--fail-on-supply-chain high]

      Runs the mechanical pipeline (no LLM stages) end-to-end and
      decides pass/fail from the resulting findings.

  raptor-sca-gate --findings <path> [thresholds...]

      Reads an existing ``findings.json`` produced by an earlier run
      and applies the same thresholds — useful when the gate is the
      only step left in CI after a longer ``/sca`` job.

Exit codes:
  0 — gate passed (no finding exceeded thresholds)
  1 — gate failed (one or more findings exceed thresholds)
  2 — invalid arguments
  3 — internal error

Thresholds:
  --severity {info,low,medium,high,critical}
       Fail if any vulnerable_dependency finding meets-or-exceeds this
       severity. Default: ``high``. Use ``critical`` to only fail on
       critical CVEs; use ``low`` to make the gate strict.
  --fail-on-kev
       Fail if any vulnerable_dependency is on CISA's KEV list, even
       below the severity threshold.
  --fail-on-supply-chain {info,low,medium,high,critical}
       Fail if any supply_chain finding meets-or-exceeds this severity.
       Default: off (set explicitly to enable).
  --fail-on-hygiene {info,low,medium,high,critical}
       Same for hygiene findings. Default: off.

The gate intentionally does *not* run KEV/EPSS network calls when
``--findings`` is supplied (the upstream run already did the work).
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path
from typing import List, Optional, Sequence

_REPO = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(_REPO))

from packages.sca.cli import _configure_logging                      # noqa: E402
from packages.sca.findings import severity_rank                      # noqa: E402
from packages.sca.pipeline import RunOptions, run_sca                # noqa: E402

_VALID_SEVERITIES = ("info", "low", "medium", "high", "critical")


def _parse(argv: Sequence[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(prog="raptor-sca-gate")
    p.add_argument("target", nargs="?",
                   help="path to project (omit when --findings is set)")
    p.add_argument("--findings",
                   help="read findings.json from this path instead of "
                        "running the pipeline")
    p.add_argument("--severity",
                   choices=_VALID_SEVERITIES,
                   default="high",
                   help="severity threshold for vulnerable_dependency "
                        "findings (default: high)")
    p.add_argument("--fail-on-kev", action="store_true",
                   help="fail when any vulnerable_dependency is in CISA KEV")
    p.add_argument("--fail-on-supply-chain", default=None,
                   choices=_VALID_SEVERITIES,
                   help="fail when supply_chain findings reach this severity")
    p.add_argument("--fail-on-hygiene", default=None,
                   choices=_VALID_SEVERITIES,
                   help="fail when hygiene findings reach this severity")
    p.add_argument("--include-suppressed", action="store_true",
                   help="evaluate findings the operator marked as suppressed "
                        "in .raptor-sca-suppress.yml (default: skip them)")
    p.add_argument("--out", help="output dir for the run "
                                 "(ignored when --findings is set)")
    p.add_argument("--offline", action="store_true")
    p.add_argument("--no-cache", action="store_true")
    p.add_argument("--cache-root")
    p.add_argument(
        "--clean-cache", action="store_true",
        help="delete stale cache entries and exit",
    )
    p.add_argument(
        "--max-age", type=int, default=None, metavar="DAYS",
        help="for --clean-cache: delete entries older than DAYS "
             "(default 30)",
    )
    p.add_argument("-v", "--verbose", action="count", default=0)
    return p.parse_args(argv)


def main(argv: Optional[Sequence[str]] = None) -> int:
    args = _parse(argv if argv is not None else sys.argv[1:])
    _configure_logging(args.verbose)

    # Cache-maintenance short-circuit. ``--clean-cache`` is a one-shot
    # space-reclamation op, not a gate evaluation; runs and exits 0 on
    # success, 3 on filesystem error.
    if args.clean_cache:
        from packages.sca import SCA_CACHE_ROOT
        from packages.sca.cache_eviction import (
            DEFAULT_MAX_AGE_DAYS, evict_stale,
        )
        cache_root = (Path(args.cache_root).resolve()
                      if args.cache_root else SCA_CACHE_ROOT)
        max_age = args.max_age if args.max_age is not None else DEFAULT_MAX_AGE_DAYS
        if max_age <= 0:
            print(f"raptor-sca-gate: --max-age must be positive, got {max_age}",
                  file=sys.stderr)
            return 2
        try:
            res = evict_stale(cache_root, max_age_days=max_age)
        except Exception as e:                  # noqa: BLE001
            print(f"raptor-sca-gate: cache eviction failed: {e}",
                  file=sys.stderr)
            return 3
        mb = res.bytes_freed / (1024 * 1024)
        print(
            f"raptor-sca-gate: cleaned {res.files_removed}/"
            f"{res.files_scanned} entries "
            f"({mb:.1f} MB), removed {res.dirs_removed} empty dirs"
            + (f", {res.errors} errors" if res.errors else "")
            + f" from {cache_root}"
        )
        return 0

    if args.findings:
        path = Path(args.findings).resolve()
        if not path.exists():
            print(f"raptor-sca-gate: findings file not found: {path}",
                  file=sys.stderr)
            return 2
        try:
            rows = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as e:
            print(f"raptor-sca-gate: cannot read {path}: {e}",
                  file=sys.stderr)
            return 2
        if not isinstance(rows, list):
            print(f"raptor-sca-gate: {path} is not a finding list",
                  file=sys.stderr)
            return 2
        return _evaluate_thresholds(rows, args)

    target = _resolve_target(args.target)
    if target is None:
        print("raptor-sca-gate: must supply <target> or --findings",
              file=sys.stderr)
        return 2
    if not target.exists() or not target.is_dir():
        print(f"raptor-sca-gate: target not a directory: {target}",
              file=sys.stderr)
        return 2

    output_dir = (
        Path(args.out).resolve() if args.out
        else Path("out") / f"sca-gate-{os.getpid()}"
    )
    output_dir.mkdir(parents=True, exist_ok=True)

    options = RunOptions(
        offline=args.offline,
        no_cache=args.no_cache,
        cache_root=Path(args.cache_root) if args.cache_root else None,
    )

    try:
        result = run_sca(target=target, output_dir=output_dir, options=options)
    except Exception as e:                  # noqa: BLE001
        print(f"raptor-sca-gate: pipeline failed: {e}", file=sys.stderr)
        return 3

    rows = json.loads(result.findings_path.read_text(encoding="utf-8"))
    return _evaluate_thresholds(rows, args)


# ---------------------------------------------------------------------------
# Threshold evaluation
# ---------------------------------------------------------------------------

def _evaluate_thresholds(
    rows: List[dict], args: argparse.Namespace,
) -> int:
    sev_floor = severity_rank(args.severity)
    sc_floor = (
        severity_rank(args.fail_on_supply_chain)
        if args.fail_on_supply_chain else None
    )
    hyg_floor = (
        severity_rank(args.fail_on_hygiene)
        if args.fail_on_hygiene else None
    )

    fails: List[str] = []
    for row in rows:
        if row.get("suppressed") and not args.include_suppressed:
            continue
        vuln_type = row.get("vuln_type", "")
        sev = row.get("severity", "info")
        rank = severity_rank(sev)
        if vuln_type == "sca:vulnerable_dependency":
            if rank >= sev_floor:
                fails.append(
                    f"[{sev}] {row.get('description') or row.get('id')}"
                )
                continue
            if args.fail_on_kev and row.get("sca", {}).get("in_kev"):
                fails.append(
                    f"[KEV] {row.get('description') or row.get('id')}"
                )
        elif vuln_type.startswith("sca:supply_chain:"):
            if sc_floor is not None and rank >= sc_floor:
                fails.append(
                    f"[supply-chain {sev}] "
                    f"{row.get('description') or row.get('id')}"
                )
        elif vuln_type.startswith("sca:hygiene:"):
            if hyg_floor is not None and rank >= hyg_floor:
                fails.append(
                    f"[hygiene {sev}] "
                    f"{row.get('description') or row.get('id')}"
                )

    if not fails:
        print("raptor-sca-gate: pass — no findings above thresholds")
        return 0

    print(f"raptor-sca-gate: fail — {len(fails)} finding(s) above thresholds:",
          file=sys.stderr)
    for line in fails[:50]:
        print(f"  {line}", file=sys.stderr)
    if len(fails) > 50:
        print(f"  … and {len(fails) - 50} more", file=sys.stderr)
    return 1


def _resolve_target(explicit: Optional[str]) -> Optional[Path]:
    if explicit:
        return Path(explicit).resolve()
    caller = os.environ.get("RAPTOR_CALLER_DIR")
    if caller:
        return Path(caller).resolve()
    return None


if __name__ == "__main__":
    sys.exit(main())
